generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionTierType {
  Free
  PRO
  ENTERPRISE
}

enum SubscriptionStatusType {
  ACTIVE
  INACTIVE
  CANCELED
}

enum MediaPost {
  X
  YOUTUBE
  INSTAGRAM
  PEERLIST
  REDDIT
  LINKEDIN
}

enum PreferredPostTopic {
  TECH
  SCIENCE
  POLITICS
  BUSINESS
  AI
  PROGRAMMING
  CYBERSECURITY
  SPACE
  STARTUPS
}

enum PostStatus {
  PENDING
  REVIEWED
  POSTED
  SKIPPED
}

enum PostMadeByType {
  CRON
  MANNUAL
}

enum TrendSource {
  REDDIT
  HACKERNEWS
  GOOGLE_TRENDS
  NEWS
}

model User {
  id                  String                 @id
  name                String
  email               String
  emailVerified       Boolean                @default(false)
  image               String?
  createdAt           DateTime               @default(now())
  role                Role                   @default(USER)
  subscriptionTier    SubscriptionTierType   @default(Free)
  subscriptionStatus  SubscriptionStatusType @default(INACTIVE)
  polarCustomerId     String?                @unique // Store the Polar customer ID for billing purposes
  polarSubscriptionId String?                @unique // Store the Polar subscription ID for billing purposes
  preferredPostMedia  MediaPost[]
  preferredPostTopics PreferredPostTopic[]
  updatedAt           DateTime               @updatedAt
  sessions            Session[]
  accounts            Account[]
  aiposts             AIPosts[]
  userUsage           UserUsage?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AIPosts {
  id String @id @default(uuid())

  mediaPosts      MediaPost          @default(X)
  postTopics      PreferredPostTopic @default(TECH)
  postMadeBy      PostMadeByType     @default(CRON)
  title           String
  content         Json
  source          TrendSource?
  sourceUrl       String?
  trendScore      Decimal?           @db.Decimal(4, 3)
  engagementScore Int?
  commentCount    Int?
  tokensConsumed  Decimal?           @db.Decimal(12, 2)
  hash            String?            @unique
  status          PostStatus         @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id])

  isPosted     Boolean @default(false)
  errorMessage String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([trendScore])
  @@index([createdAt])
  @@index([status])
  @@index([topicId])
  @@index([userId])
}

model Topic {
  id String @id @default(uuid())

  query    String             @unique
  category PreferredPostTopic

  trendScore Decimal? @db.Decimal(4, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts AIPosts[]

  @@index([query])
}

model UserUsage {
  id              String @id @default(cuid())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  TotalTokenConsumed  Decimal?               @db.Decimal(12, 2)
  dailyTokenConsumed  Decimal?               @db.Decimal(12, 2)
  
  generationCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_usage")
}
